# LynShae Backend 环境变量配置
# 复制此文件为 .env 并填入实际值

# ==================== 服务器配置 ====================
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lynshae_db
DB_USER=root
DB_PASSWORD=your_mysql_password

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== JWT 配置 ====================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ==================== 文件上传配置 ====================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ==================== 安全配置 ====================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== CORS 配置 ====================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://10.0.2.2:3000
CORS_CREDENTIALS=true

# ==================== 日志配置 ====================
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# ==================== 邮件配置 (可选) ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=LynShae <noreply@lynshae.com>

# ==================== 对象存储配置 (可选) ====================
OSS_PROVIDER=local
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
