# LynShae 灵羲智能 - 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ============================================
# 运行环境
# ============================================
NODE_ENV=production

# ============================================
# 数据库配置 (MySQL)
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lynshae_db
DB_USER=lynshae
DB_PASSWORD=LynShae@2026

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=lynshae-prod-secret-key-change-me-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# 端口配置
# ============================================
BACKEND_PORT=3005
WEB_PORT=3006
DB_PORT=3306
REDIS_PORT=6379

# ============================================
# CORS 配置
# ============================================
CORS_ORIGIN=http://localhost:3006,http://localhost:5173
CORS_CREDENTIALS=true

# ============================================
# Web 管理后台 API 地址
# ============================================
VITE_API_BASE_URL=http://localhost:3005/api/v1

# ============================================
# 文件上传配置
# ============================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ============================================
# 安全配置
# ============================================
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log
